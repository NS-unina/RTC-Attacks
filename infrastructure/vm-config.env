# Multipass VM Configuration
# Edit these values to customize VM instances and ensure experimental replicability

# VM naming
VM_NAME_PREFIX=rtc-vm

# Network configuration
# Custom bridge network for VMs with static IPs (10.30.0.0/24)
# Run: ./setup-bridge.sh to create the bridge first
VM_BRIDGE=br-rtc
VM_BASE_IP=10.30.0.10
VM_NETMASK=24
VM_GATEWAY=10.30.0.1
# VMs will have IPs: 10, 11, 12, 13, 14, 15

# VM resources (for consistent performance across experiments)
VM_RAM=4G
VM_DISK=60G
VM_CPUS=8

# CPU pinning (set to "true" to pin CPUs for isolation, reduces interference)
# When enabled, each VM gets dedicated CPU cores
VM_CPU_PINNING=false
VM_CPU_START_CORE=0

# Memory settings (for reproducibility)
# Disable swap to avoid performance variance
VM_DISABLE_SWAP=true
# Memory overcommit (0=heuristic, 1=always, 2=never)
VM_MEMORY_OVERCOMMIT=2

# Network QoS and limits (useful for testing under constrained conditions)
# Bandwidth limit in Mbit/s (empty = unlimited)
VM_NETWORK_BANDWIDTH_LIMIT=
# Network latency in ms (empty = no artificial latency)
VM_NETWORK_LATENCY=
# Packet loss percentage (empty = no loss)
VM_NETWORK_PACKET_LOSS=

# Disk I/O limits (for consistent disk performance)
# Read/write IOPS limits (empty = unlimited)
VM_DISK_READ_IOPS=
VM_DISK_WRITE_IOPS=
# Read/write bandwidth in MB/s (empty = unlimited)
VM_DISK_READ_BPS=
VM_DISK_WRITE_BPS=

# Time synchronization (critical for experiment logging)
VM_NTP_SERVERS=pool.ntp.org
VM_TIMEZONE=Europe/Rome

# Docker and container runtime (auto-install if true)
VM_INSTALL_DOCKER=true
VM_DOCKER_VERSION=latest

# Monitoring tools (auto-install if true)
VM_INSTALL_MONITORING=true
# Installs: sysstat, iftop, htop, iotop, nethogs, stress-ng

# Instance range (230-235 = 6 instances max)
VM_MAX_INSTANCES=5
VM_START_INDEX=0

# OS image
VM_IMAGE=26.04

# Cloud-init customization file (optional, for advanced provisioning)
VM_CLOUD_INIT_FILE=
