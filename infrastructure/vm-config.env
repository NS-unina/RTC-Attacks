# Multipass VM Configuration
# Edit these values to customize VM instances

# VM naming
VM_NAME_PREFIX=rtc-vm

# Network configuration
VM_BASE_IP=10.0.0.230
VM_NETMASK=24
VM_GATEWAY=10.0.0.1
VM_BRIDGE_INTERFACE=enp3s0

# VM resources
VM_RAM=32G
VM_DISK=60G
VM_CPUS=8

# Instance range (230-235 = 6 instances max)
VM_MAX_INSTANCES=5
VM_START_INDEX=0

# OS image
VM_IMAGE=22.04
